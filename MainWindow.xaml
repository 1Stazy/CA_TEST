<Window x:Class="CinemaSystem.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
        xmlns:views="clr-namespace:CinemaSystem.Desktop.Views"
        mc:Ignorable="d"
        Title="Kino System" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Black">
    
    <!-- ContentControl powiązany z MainViewModel.CurrentView - automatycznie zmienia widok -->
    <ContentControl Content="{Binding CurrentView}">
        <!-- Mapping ViewModeli na Views - WPF wybiera odpowiedni DataTemplate na podstawie typu danych -->
        <ContentControl.Resources>
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MoviesViewModel}">
                <views:MoviesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SeatSelectionViewModel}">
                <views:SeatSelectionView/>
            </DataTemplate>
        </ContentControl.Resources>
    </ContentControl>
</Window>
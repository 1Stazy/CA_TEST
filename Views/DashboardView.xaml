<UserControl x:Class="CinemaSystem.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="#121212">

    <UserControl.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Foreground" Value="#EF5350"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#350000"/>
                    <Setter Property="Foreground" Value="#FF5252"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="30,40,30,40">
                    <TextBlock Text="KINO SYSTEM" Foreground="#FFD700" FontSize="26" FontWeight="Black"/>
                    <Border Background="#2A2A2A" CornerRadius="8" Padding="15" Margin="0,25,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="35" Height="35" Background="#333" Margin="0,0,15,0">
                                <Path Data="M12,12c2.21,0 4,-1.79 4,-4s-1.79,-4 -4,-4s-4,1.79 -4,4s1.79,4 4,4z M12,14c-2.67,0 -8,1.34 -8,4v2h16v-2c0,-2.66 -5.33,-4 -8,-4z" Fill="#FFD700" Stretch="Uniform" Margin="7"/>
                            </Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Zalogowano jako:" Foreground="#666" FontSize="11"/>
                                <TextBlock Text="{Binding UserNameDisplay}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="20,0">
                    <Button Content="REPERTUAR FILMÓW" Command="{Binding NavigateToMoviesCommand}" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="ZARZĄDZANIE BILETAMI" Command="{Binding GoToTicketManagementCommand}" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="HARMONOGRAM (KASJER)" Command="{Binding NavigateToScheduleCommand}" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="STATYSTYKI" Command="{Binding NavigateToReportsCommand}" Style="{StaticResource MenuButtonStyle}"/>

                    <Separator Background="#333" Margin="0,15,0,15"/>

                    <Button Content="HARMONOGRAM (KLIENT)" Command="{Binding ShowClientScheduleCommand}" 
                            Style="{StaticResource MenuButtonStyle}"
                            ToolTip="Wyświetla harmonogram na ekranie klienta przez 30s"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,0,20,30">
                    <Separator Background="#333" Margin="0,0,0,20"/>
                    <Button Content="WYLOGUJ SIĘ" Command="{Binding LogoutCommand}" Style="{StaticResource LogoutButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" ClipToBounds="True">
            <ContentControl Content="{Binding CurrentContent}"/>
        </Border>
    </Grid>
</UserControl>
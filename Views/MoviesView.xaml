<UserControl x:Class="CinemaSystem.Desktop.Views.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
             xmlns:controls="clr-namespace:CinemaSystem.Desktop.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="400" Background="#0F0F0F" ClipToBounds="True">
            <TextBlock Text="POLECAMY NA DZIŚ" 
                
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       FontSize="24" FontWeight="Bold" Foreground="#FFD700"
                       Margin="20,25,0,0" Panel.ZIndex="1">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <controls:Carousel3DView x:Name="MainCarousel"
                                     ItemsSource="{Binding RecommendedMovies}" 
                                     SelectedItem="{Binding SelectedRecommendedMovie, Mode=TwoWay}"
                                     CameraDistance="18"
                                     Margin="0,60,0,0"/>

            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                    Margin="0,0,0,30" Padding="20,10"
                    Background="#CC000000" CornerRadius="15"
                    Panel.ZIndex="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedRecommendedMovie}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SelectedRecommendedMovie.Title}" 
                               Foreground="White" FontSize="22" FontWeight="Bold" 
                               TextAlignment="Center" Margin="0,0,0,10">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Button Content="ZAREZERWUJ TERAZ"
                            Command="{Binding DataContext.NavigateToDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding SelectedRecommendedMovie}"
                            Background="#E50914" Foreground="White" FontWeight="Bold" FontSize="14"
                            Padding="30,10" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
            
            <Border VerticalAlignment="Top" HorizontalAlignment="Right" 
                    Background="#FFD700" CornerRadius="10" Padding="10,5" Margin="30,20">
                 <TextBlock Text="{Binding SelectedRecommendedMovie.ImdbRating}" 
                            FontWeight="Bold" FontSize="18" Foreground="Black"/>
             </Border>
        </Grid>

        <Border Grid.Row="1" Background="#1E1E1E" Padding="20,15" BorderBrush="#333" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#2A2A2A" CornerRadius="20" Padding="15,0" 
                        Cursor="IBeam"
                        MouseLeftButtonDown="FocusSearchBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="🔍" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Szukaj filmu (tytuł, reżyser, rok)..." 
                                       Foreground="#666" FontSize="16" 
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" 
                                     Foreground="White" 
                                     BorderThickness="0" 
                                     FontSize="16" 
                                     CaretBrush="#FFD700"
                                     VerticalContentAlignment="Center"
                                     Height="40"/>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="Znaleziono: " Foreground="Gray"/>
                    <TextBlock Text="{Binding Movies.Count}" Foreground="#FFD700" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" VerticalAlignment="Bottom" Padding="20,15,20,0" Background="Transparent">
            <ItemsControl ItemsSource="{Binding Genres}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}" 
                                  Content="{Binding Name}"
                                  Margin="0,0,10,10" Cursor="Hand">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="Back" CornerRadius="4" Height="32" Padding="12,0"
                                            BorderBrush="#444" BorderThickness="1" Background="Transparent">
                                        
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal"/>
                                                <VisualState x:Name="MouseOver">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="Back" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FFD700" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Pressed"/>
                                                <VisualState x:Name="Disabled"/>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path x:Name="Icon" 
                                                  Data="M21.41 11.58 L12.41 2.58 C12.05 2.22 11.55 2 11 2 H4 C2.89 2 2 2.89 2 4 V11 C2 11.55 2.22 12.05 2.59 12.41 L11.58 21.41 C11.95 21.77 12.45 22 13 22 C13.55 22 14.05 21.77 14.41 21.41 L21.41 14.41 C21.78 14.05 22 13.55 22 13 C22 12.45 21.77 11.94 21.41 11.58 Z M5.5 7 A1.5 1.5 0 0 1 4 5.5 A1.5 1.5 0 0 1 5.5 4 A1.5 1.5 0 0 1 7 5.5 A1.5 1.5 0 0 1 5.5 7 Z" 
                                                  Fill="#666" 
                                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                            
                                            <ContentPresenter x:Name="Txt" 
                                                              TextBlock.Foreground="#888" 
                                                              TextBlock.FontWeight="SemiBold" 
                                                              TextBlock.FontSize="13"
                                                              VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Back" Property="Background" Value="#FFD700"/>
                                            <Setter TargetName="Back" Property="BorderBrush" Value="#FFD700"/>
                                            <Setter TargetName="Icon" Property="Fill" Value="Black"/>
                                            <Setter TargetName="Txt" Property="TextBlock.Foreground" Value="Black"/>
                                            <Setter TargetName="Back" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Txt" Property="TextBlock.Foreground" Value="White"/>
                                            <Setter TargetName="Icon" Property="Fill" Value="White"/>
                                        </Trigger>
                                        
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsChecked" Value="True"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Txt" Property="TextBlock.Foreground" Value="#222"/>
                                            <Setter TargetName="Icon" Property="Fill" Value="#222"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="20">
            <ItemsControl ItemsSource="{Binding Movies}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="340" Margin="10" 
                                Background="#1E1E1E" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
                            </Border.Effect>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                    <Image Source="{Binding PosterUri}" Stretch="UniformToFill"/>
                                </Border>
                                <Border VerticalAlignment="Top" HorizontalAlignment="Right" Background="#FFD700" CornerRadius="0,8,0,8" Padding="6,2">
                                    <TextBlock Text="{Binding ImdbRating}" FontWeight="Bold" FontSize="12"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="10">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Director.Name, StringFormat='Reż: {0}', FallbackValue='Reż: -'}" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Button Grid.Row="2" Content="REZERWUJ" 
                                        Command="{Binding DataContext.NavigateToDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="10,0,10,10" Height="30"
                                        Background="#E50914" Foreground="White" FontWeight="Bold" BorderThickness="0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.RowSpan="4" Background="#80000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Ładowanie..." Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        
        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsSearchEmpty, Converter={StaticResource BoolToVis}}">
            <TextBlock Text=":(" FontSize="40" HorizontalAlignment="Center" Foreground="Gray"/>
            <TextBlock Text="Nie znaleziono takiego filmu." 
                       FontSize="20" Foreground="Gray" FontWeight="SemiBold" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
<Window x:Class="CinemaSystem.Desktop.Views.BookingConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potwierdzenie" Height="380" Width="540"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1E1E1E" CornerRadius="15" BorderBrush="#333" BorderThickness="1" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="80" Height="80" CornerRadius="40" Background="#FFD700" Margin="0,0,0,40">
                    <Path Data="M 0,10 L 5,15 L 15,0" 
                          Stroke="Black" 
                          StrokeThickness="4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Stretch="Uniform"
                          Width="35" Height="35"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"
                          Margin="0,3,0,0"/> </Border>

                <TextBlock Text="REZERWACJA POMYŚLNA!" 
                           Foreground="White" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Twoje bilety zostały wygenerowane." 
                           Foreground="Gray" FontSize="16" 
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Button x:Name="BtnOpenPdf" Content="OTWÓRZ BILET (PDF)" 
                        Click="BtnOpenPdf_Click"
                        Width="180" Height="45" Margin="10"
                        Background="#E50914" Foreground="White" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnClose" Content="ZAMKNIJ" 
                        Click="BtnClose_Click"
                        Width="120" Height="45" Margin="10"
                        Background="#333" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
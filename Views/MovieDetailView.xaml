<UserControl x:Class="CinemaSystem.Desktop.Views.MovieDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Background="#121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.5*"/> 
            <ColumnDefinition Width="6.5*"/>   
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Image Source="{Binding SelectedFilm.PosterUri}" 
                   Stretch="UniformToFill" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
            
            <Border Background="Black" Opacity="0.3"/>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#FF121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Button Command="{Binding GoBackCommand}" 
                    VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20"
                    Background="#99000000" Foreground="White" Width="40" Height="40"
                    Content="←" FontSize="24" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <ScrollViewer Grid.Column="1" Margin="40,40,40,20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding SelectedFilm.Genre}" Foreground="#FFD700" FontSize="16" FontWeight="Bold" Opacity="0.8"/>
                <TextBlock Text="{Binding SelectedFilm.Title}" Foreground="White" FontSize="56" FontWeight="Bold" TextWrapping="Wrap" Margin="0,5,0,20" LineHeight="60"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Background="#333" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding SelectedFilm.Duration, StringFormat='{}{0} min'}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#333" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding SelectedFilm.ReleaseDate}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <Border BorderBrush="#FFD700" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★" Foreground="#FFD700" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding SelectedFilm.ImdbRating}" Foreground="#FFD700" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Text="OPIS FABUŁY" Foreground="Gray" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SelectedFilm.Description}" 
                           Foreground="#DDD" FontSize="18" LineHeight="28" TextWrapping="Wrap" Opacity="0.9" MaxWidth="800" HorizontalAlignment="Left"/>
                
                <Separator Background="#333" Margin="0,40"/>

                <TextBlock Text="WYBIERZ SEANS" Foreground="#FFD700" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding FilmScreenings}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            
                            <Button Command="{Binding DataContext.BuyTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,25,25" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Cursor="Hand"
                                    UseLayoutRounding="True"> <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Width="160">
                                            <Border x:Name="ShadowLayer" 
                                                    Background="#FFD700" 
                                                    CornerRadius="10" 
                                                    Opacity="0"
                                                    Margin="5,10,5,0"> <Border.Effect>
                                                    <BlurEffect Radius="15"/>
                                                </Border.Effect>
                                            </Border>

                                            <Border x:Name="MainCard" 
                                                    Background="#1E1E1E" 
                                                    BorderBrush="#333" 
                                                    BorderThickness="1" 
                                                    CornerRadius="10" 
                                                    Padding="0">
                                                <Border.RenderTransform>
                                                    <TranslateTransform Y="0"/>
                                                </Border.RenderTransform>
                                                
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0" Background="#252525" CornerRadius="10,10,0,0" Padding="15">
                                                        <TextBlock Text="{Binding TimeString}" Foreground="#FFD700" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <Border Grid.Row="1" Padding="15">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DateString}" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                            <TextBlock Text="{Binding Hall.Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Row="2" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10">
                                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" Foreground="#AAA" FontSize="12" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                        
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="MainCard" Property="BorderBrush" Value="#FFD700"/>
                                                <Setter TargetName="MainCard" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform Y="-5"/>
                                                    </Setter.Value>
                                                </Setter>
                                                
                                                <Setter TargetName="ShadowLayer" Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                            
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="MainCard" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform Y="-2"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="ShadowLayer" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock Text="Brak zaplanowanych seansów na najbliższe dni." 
                           Foreground="Gray" FontStyle="Italic" Margin="0,20,0,0" FontSize="16"
                           Visibility="{Binding FilmScreenings.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/> 
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
<UserControl x:Class="CinemaSystem.Desktop.Views.SeatSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <d:UserControl.DataContext>
        <vm:SeatSelectionViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <ControlTemplate x:Key="InteractiveSeatTemplate" TargetType="Button">
            <Grid Width="44" Height="48" Margin="2">
                <Grid VerticalAlignment="Top" Height="42">
                    <Grid.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="3" Opacity="0.7"/>
                    </Grid.Effect>

                    <Border x:Name="SeatBack" 
                            Background="#1E1E1E" 
                            BorderBrush="#333" 
                            BorderThickness="2"
                            CornerRadius="4,4,2,2"
                            Margin="6,0,6,10"/>

                    <Border x:Name="SeatCushion"
                            Background="#252525"
                            BorderBrush="#333" BorderThickness="1"
                            CornerRadius="3"
                            Height="16" VerticalAlignment="Bottom" Margin="4,0,4,2"/>

                    <Border Width="5" HorizontalAlignment="Left" Margin="0,12,0,2" 
                            Background="#101010" BorderBrush="#222" BorderThickness="1" CornerRadius="2"/>
                    
                    <Border Width="5" HorizontalAlignment="Right" Margin="0,12,0,2" 
                            Background="#101010" BorderBrush="#222" BorderThickness="1" CornerRadius="2"/>

                    <TextBlock x:Name="SeatNum" Text="{Binding Number}" 
                            Foreground="#666" FontSize="11" FontWeight="Bold" 
                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>
                </Grid>

                <Border x:Name="SeatGlow" VerticalAlignment="Bottom" Height="2" Background="#FFD700" Opacity="0" CornerRadius="1">
                    <Border.Effect><BlurEffect Radius="4"/></Border.Effect>
                </Border>
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Selected">
                    <Setter TargetName="SeatBack" Property="Background" Value="#FFD700"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#E5C100"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#FFD700"/>
                    <Setter TargetName="SeatBack" Property="Effect">
                        <Setter.Value><DropShadowEffect Color="#FFD700" BlurRadius="15" Opacity="0.6"/></Setter.Value>
                    </Setter>
                    <Setter TargetName="SeatNum" Property="Foreground" Value="Black"/>
                    <Setter TargetName="SeatGlow" Property="Opacity" Value="1"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Taken">
                    <Setter TargetName="SeatBack" Property="Background" Value="#350000"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#450000"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#450000"/>
                    <Setter TargetName="SeatNum" Property="Visibility" Value="Collapsed"/>
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Editing">
                    <Setter TargetName="SeatBack" Property="Background" Value="#9b59b6"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#8e44ad"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#8e44ad"/>
                    <Setter TargetName="SeatNum" Property="Foreground" Value="White"/>
                    <Setter TargetName="SeatBack" Property="Effect">
                        <Setter.Value><DropShadowEffect Color="#9b59b6" BlurRadius="15" Opacity="0.8"/></Setter.Value>
                    </Setter>
                    <Setter Property="IsEnabled" Value="False"/> <Setter Property="Opacity" Value="0.9"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding Status}" Value="Available"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SeatBack" Property="Background" Value="#333"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#888"/> 
                    <Setter TargetName="SeatCushion" Property="Background" Value="#383838"/>
                    <Setter TargetName="SeatNum" Property="Foreground" Value="White"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </MultiDataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Background="#050505">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <RowDefinition Height="*"/>     <RowDefinition Height="Auto"/>  </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="50,30,50,0">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentScreening.TimeString}" Foreground="#FFD700" FontSize="56" FontWeight="Black" Margin="0,0,20,0">
                        <TextBlock.Effect><DropShadowEffect Color="#FFD700" BlurRadius="20" Opacity="0.4"/></TextBlock.Effect>
                    </TextBlock>
                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12,4" VerticalAlignment="Center" Background="#151515">
                        <TextBlock Text="{Binding CurrentScreening.Hall.Name}" Foreground="#AAA" FontSize="24" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding CurrentScreening.Movie.Title}" Foreground="White" FontSize="40" FontWeight="Light" Margin="0,5,0,0" Opacity="0.95"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                <Path Data="M 0,0 L 800,0 L 740,80 L 60,80 Z" 
                      Fill="#1E1E1E" Stroke="#444" StrokeThickness="3">
                    <Path.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
                    </Path.Effect>
                </Path>
                
                <TextBlock Text="E K R A N" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,-55,0,0" Opacity="0.8"/>
                
                <Border Height="6" Width="680" Background="#FFD700" Margin="0,48,0,0" Opacity="0.5" CornerRadius="3">
                    <Border.Effect>
                        <BlurEffect Radius="15"/>
                    </Border.Effect>
                </Border>
            </StackPanel>
        </Grid>

        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="50,10,50,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                <ItemsControl Grid.Column="0" ItemsSource="{Binding RowLabels}" Margin="0,0,30,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="50"> <TextBlock Text="{Binding}" Foreground="#FFD700" FontSize="24" FontWeight="Bold" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.5"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Column="1" x:Name="SelectionArea" 
                      Background="Transparent"
                      MouseLeftButtonDown="OnMouseDown"
                      MouseMove="OnMouseMove"
                      MouseLeftButtonUp="OnMouseUp">

                    <ItemsControl x:Name="SeatsControl" ItemsSource="{Binding Seats}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding ColumnsCount}" Rows="{Binding RowsCount}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ToggleSeatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Template="{StaticResource InteractiveSeatTemplate}"
                                        ToolTip="{Binding DisplayName}"
                                        IsHitTestVisible="True"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas IsHitTestVisible="False">
                        <Rectangle x:Name="SelectionBox"
                                   Stroke="#FFD700"
                                   StrokeThickness="2"
                                   Fill="#33FFD700"
                                   Visibility="Collapsed"/>
                    </Canvas>
                </Grid>

                <ItemsControl Grid.Column="2" ItemsSource="{Binding RowLabels}" Margin="30,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="50">
                                <TextBlock Text="{Binding}" Foreground="#FFD700" FontSize="24" FontWeight="Bold" 
                                           VerticalAlignment="Center" HorizontalAlignment="Left" Opacity="0.5"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>

        <Border Grid.Row="2" Background="#101010" BorderBrush="#222" BorderThickness="0,1,0,0" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="LEGENDA:" Foreground="#666" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    
                    <Border Width="16" Height="16" Background="#1E1E1E" CornerRadius="3" Margin="0,0,8,0" BorderBrush="#333" BorderThickness="1"/>
                    <TextBlock Text="Wolne" Foreground="#AAA" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    
                    <Border Width="16" Height="16" Background="#FFD700" CornerRadius="3" Margin="0,0,8,0"/>
                    <TextBlock Text="Wybrane" Foreground="White" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    
                    <Border Width="16" Height="16" Background="#350000" CornerRadius="3" Margin="0,0,8,0"/>
                    <TextBlock Text="Zajęte" Foreground="#AAA" Margin="0,0,20,0" VerticalAlignment="Center"/>

                    <Border Width="16" Height="16" Background="#9b59b6" CornerRadius="3" Margin="0,0,8,0">
                        <Border.Effect><DropShadowEffect Color="#9b59b6" BlurRadius="5"/></Border.Effect>
                    </Border>
                    <TextBlock Text="Poprzednie" Foreground="#9b59b6" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding SummaryText}" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,40,0"/>
                    
                    <Button Content="ANULUJ" Command="{Binding CancelCommand}" 
                            Background="Transparent" Foreground="#888" BorderThickness="0" 
                            Margin="0,0,20,0" FontWeight="SemiBold" FontSize="16" Cursor="Hand">
                         <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="POTWIERDŹ" 
                            Command="{Binding ConfirmBookingCommand}" 
                            Width="220" Height="50" 
                            Background="#E50914" Foreground="White" 
                            FontWeight="Bold" FontSize="18" 
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="25"/>
                            </Style>
                        </Button.Resources>
                        <Button.Effect>
                            <DropShadowEffect Color="#E50914" BlurRadius="20" Opacity="0.4"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FF1F2F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
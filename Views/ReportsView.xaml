<UserControl x:Class="CinemaSystem.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaSystem.Desktop.Services.Converters"
             Background="#121212">
    
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToColorConverter x:Key="BooleanToColorConverter"/>

        <Style x:Key="CustomCalendarDayButtonStyle" TargetType="CalendarDayButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="DayBorder" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayBorder" Property="Background" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="DayBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="25"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomCalendarItemStyle" TargetType="{x:Type CalendarItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CalendarItem}">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                                <TextBlock Foreground="#888" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Margin="0,5" Text="{Binding}"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>
                        <Grid x:Name="PART_Root">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="Transparent" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PART_PreviousButton" Grid.Column="0" Style="{StaticResource CalendarNavButtonStyle}">
                                        <Path Data="M 6,0 L 0,6 L 6,12" Stroke="Black" StrokeThickness="2" Margin="3,0,0,0"/>
                                    </Button>
                                    <Button x:Name="PART_HeaderButton" Grid.Column="1" Foreground="#FFD700" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" IsHitTestVisible="False"/>
                                    <Button x:Name="PART_NextButton" Grid.Column="2" Style="{StaticResource CalendarNavButtonStyle}">
                                        <Path Data="M 0,0 L 6,6 L 0,12" Stroke="Black" StrokeThickness="2" Margin="0,0,3,0"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid x:Name="PART_MonthView">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                                <Grid x:Name="PART_YearView" Visibility="Hidden">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="#1F1E1E"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource CustomCalendarDayButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource CustomCalendarItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="10">
                            <StackPanel x:Name="PART_Root" HorizontalAlignment="Center">
                                <CalendarItem x:Name="PART_CalendarItem" Style="{TemplateBinding CalendarItemStyle}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CinemaDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#333"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="CalendarStyle" Value="{StaticResource CustomCalendarStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Foreground="White" Background="Transparent" SelectionBrush="#FFD700" VerticalAlignment="Center" Margin="5,0,0,0" BorderThickness="0" FontSize="14">
                                    <DatePickerTextBox.Style>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DatePickerTextBox">
                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DatePickerTextBox.Style>
                                </DatePickerTextBox>
                                <Button x:Name="PART_Button" Grid.Column="1" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <Path Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V10H19V20M19,8H5V6H19V8M9,14H7V12H9V14M13,14H11V12H13V14M17,14H15V12H17V14M9,18H7V16H9V18M13,18H11V16H13V18M17,18H15V16H17V18Z" Fill="#FFD700" Width="18" Height="18" Stretch="Uniform"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" StaysOpen="False" AllowsTransparency="True" Placement="Bottom">
                                    <Calendar x:Name="PART_Calendar" Style="{StaticResource CustomCalendarStyle}"/>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Border x:Name="SwitchBorder" Width="40" Height="20" CornerRadius="10" Background="#444" BorderBrush="#555" BorderThickness="1">
                                <Ellipse x:Name="SwitchDot" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="2">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" TextElement.FontSize="14"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="#FFD700"/>
                                <Setter TargetName="SwitchBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="SwitchDot" Property="Fill" Value="Black"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" Height="100" Padding="30,0" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="STATYSTYKI" Foreground="#FFD700" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Analizuj wyniki sprzedaży i frekwencję" Foreground="#888" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="ZAKRES OD" Foreground="#666" FontSize="14" FontWeight="Bold" Margin="2,0,0,2"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="140" Height="38" FontSize="14" Style="{StaticResource CinemaDatePickerStyle}"/>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,30,0">
                        <TextBlock Text="DO" Foreground="#666" FontSize="14" FontWeight="Bold" Margin="2,0,0,2"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="140" Height="38" FontSize="14" Style="{StaticResource CinemaDatePickerStyle}"/>
                    </StackPanel>

                    <Button Command="{Binding GeneratePdfCommand}" Content="POBIERZ PDF" 
                            Margin="0,0,10,0" Padding="20,0" Height="42" VerticalAlignment="Bottom" FontSize="14"
                            Background="#D32F2F" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Command="{Binding ExportToCSVCommand}" Content="CSV" ToolTip="Eksportuj surowe dane"
                            Margin="0,0,10,0" Padding="20,0" Height="42" VerticalAlignment="Bottom" FontSize="14"
                            Background="#2E7D32" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Command="{Binding ToggleConfigCommand}" 
                            ToolTip="Dostosuj układ"
                            Width="42" Height="42" VerticalAlignment="Bottom"
                            Background="#333" Foreground="White" 
                            FontFamily="Segoe MDL2 Assets" Content="&#xE713;" 
                            FontSize="20" FontWeight="Normal"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30">
                
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="280" Background="#1E1E1E" CornerRadius="8" Margin="0,0,20,20" Padding="25"
                            Visibility="{Binding ShowRevenue, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="CAŁKOWITY UTARG" Foreground="#888" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C}}" Foreground="#FFD700" FontSize="32" FontWeight="Bold" Margin="0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{Binding IsRevenueUp, Converter={StaticResource BooleanToColorConverter}}" CornerRadius="3" Padding="5,2" Margin="0,0,5,0">
                                     <TextBlock Text="{Binding RevenueTrend}" Foreground="Black" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                <TextBlock Text="vs poprz. okres" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Width="280" Background="#1E1E1E" CornerRadius="8" Margin="0,0,20,20" Padding="25"
                            Visibility="{Binding ShowATP, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="ŚR. CENA BILETU" Foreground="#888" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="{Binding AvgTicketPrice, StringFormat={}{0:C}}" Foreground="#29B6F6" FontSize="32" FontWeight="Bold" Margin="0,8"/>
                            <TextBlock Text="Przychód / Bilet" Foreground="#555" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border Width="280" Background="#1E1E1E" CornerRadius="8" Margin="0,0,20,20" Padding="25"
                            Visibility="{Binding ShowSoldTickets, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="SPRZEDANE BILETY" Foreground="#888" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="{Binding SoldTickets}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8"/>
                            <TextBlock Text="Sztuk" Foreground="#555" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border Width="280" Background="#1E1E1E" CornerRadius="8" Margin="0,0,20,20" Padding="25"
                            Visibility="{Binding ShowReturns, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="ZWROTY" Foreground="#888" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="{Binding ReturnedTickets}" Foreground="#EF5350" FontSize="32" FontWeight="Bold" Margin="0,8"/>
                            <TextBlock Text="Anulowane bilety" Foreground="#555" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border Width="280" Background="#1E1E1E" CornerRadius="8" Margin="0,0,20,20" Padding="25"
                            Visibility="{Binding ShowOccupancy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="FREKWENCJA" Foreground="#888" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="{Binding AvgOccupancy, StringFormat={}{0:F1}%}" Foreground="#66BB6A" FontSize="32" FontWeight="Bold" Margin="0,8"/>
                            <ProgressBar Value="{Binding AvgOccupancy}" Height="8" Background="#333" Foreground="#66BB6A" BorderThickness="0">
                                 <ProgressBar.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                </ProgressBar.Resources>
                            </ProgressBar>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <WrapPanel Orientation="Horizontal">
                    
                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding ShowHourlyChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="ROZKŁAD GODZINOWY" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding HourlySales}" Height="140" VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/> 
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Bottom" Margin="3,0">
                                            <Border Width="14" Height="{Binding NormalizedValue}" Background="#1E88E5" CornerRadius="2,2,0,0" ToolTip="{Binding Value}"/>
                                            <TextBlock Text="{Binding Label}" Foreground="#555" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>

                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding ShowWeeklyChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="DNI TYGODNIA" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding WeeklySales}" Height="140" VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Bottom" Margin="5,0">
                                            <TextBlock Text="{Binding Value}" Foreground="#888" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                                            
                                            <Button Command="{Binding DataContext.OpenDayDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="22" Height="{Binding NormalizedValue}" 
                                                    ToolTip="Kliknij, aby zobaczyć godziny"
                                                    Cursor="Hand" BorderThickness="0" Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="BarBorder" CornerRadius="3,3,0,0" Background="#263238"/>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Value}" Value="0">
                                                                <Setter TargetName="BarBorder" Property="Height" Value="2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWeekend}" Value="False">
                                                                <Setter TargetName="BarBorder" Property="Background" Value="#00ACC1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                                                <Setter TargetName="BarBorder" Property="Background" Value="#FFD700"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BarBorder" Property="Opacity" Value="0.8"/> </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <TextBlock Text="{Binding DayName}" Foreground="#666" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="11" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding ShowTicketTypeChart, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="STRUKTURA KLIENTÓW (TYPY BILETÓW)" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="16"/>
                            
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding TicketTypeStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,15">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="{Binding Count, StringFormat=' ({0} szt.)'}" Foreground="#666" FontSize="13"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayPercentage}" Foreground="#FFD700" FontWeight="Bold" FontSize="13"/>
                                                </Grid>

                                                <Grid Grid.Row="1" Height="6">
                                                    <Border Background="#333" CornerRadius="3"/>
                                                    
                                                    <Grid HorizontalAlignment="Left">
                                                        <ProgressBar Value="{Binding Percentage}" Maximum="100" Height="6" BorderThickness="0" Background="Transparent" Width="420">
                                                            <ProgressBar.Foreground>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#FFD700" Offset="0"/>
                                                                    <GradientStop Color="#FFA000" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </ProgressBar.Foreground>
                                                            <ProgressBar.Template>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Grid>
                                                                        <Border x:Name="PART_Track" Background="Transparent"/>
                                                                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                                                                    </Grid>
                                                                </ControlTemplate>
                                                            </ProgressBar.Template>
                                                        </ProgressBar>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding ShowHallStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="OBŁOŻENIE SAL" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="16"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding HallStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HName"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="#AAA" Width="85" FontSize="12" VerticalAlignment="Center"/>
                                                <ProgressBar Grid.Column="1" Value="{Binding Occupancy}" Maximum="100" Height="10" Background="#2A2A2A" Foreground="#FFD700" VerticalAlignment="Center" Margin="10,0" BorderThickness="0">
                                                     <ProgressBar.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                                                    </ProgressBar.Resources>
                                                </ProgressBar>
                                                <TextBlock Grid.Column="2" Text="{Binding OccupancyText}" Foreground="White" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding ShowGenreChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="GATUNKI" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="16"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding GenrePopularity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Percentage, StringFormat={}{0:F1}%}" Foreground="#888" FontSize="12"/>
                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Value="{Binding Percentage}" Height="6" Background="#2A2A2A" Foreground="#AB47BC" Margin="0,6,0,0" BorderThickness="0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Width="460" Margin="0,0,20,20" Background="#1E1E1E" CornerRadius="8" Padding="20" VerticalAlignment="Top"
                            Visibility="{Binding TopMovies, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="TOP 30 PRZYCHODÓW" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="14"/>
                            
                            <DataGrid ItemsSource="{Binding TopMovies}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None"
                                      Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                      VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="0,0,0,10"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#333"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="0,10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFD700"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    
                                    <DataGridTemplateColumn Header="TYTUŁ" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTextColumn Header="PLN" Binding="{Binding Revenue, StringFormat={}{0:C0}}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#66BB6A"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="0,0,5,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <Border Width="400" Margin="10" Background="#1E1E1E" CornerRadius="8" Padding="15" VerticalAlignment="Top"
                        Visibility="{Binding ShowMoviesTicketCount, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SPRZEDAŻ BILETOWA (TOP 30)" Foreground="White" Margin="0,0,0,15" FontWeight="Bold" FontSize="14"/>
                        
                        <DataGrid ItemsSource="{Binding TopMoviesByTickets}" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None"
                                  Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                  VerticalScrollBarVisibility="Auto" MaxHeight="400">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#333"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="0,10"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFD700"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="TYTUŁ" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="SZTUK" Binding="{Binding TicketCount}" Width="Auto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4FC3F7"/> <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.RowSpan="3" Background="#CC000000" Visibility="{Binding IsConfigOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
             <Border Width="400" Height="500" Background="#252525" CornerRadius="15" BorderBrush="#FFD700" BorderThickness="1">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="DOSTOSUJ RAPORTY" FontSize="20" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Center"/>
                        <TextBlock Text="Włącz lub wyłącz widoczność kafelków" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                        <Separator Background="#444" Margin="0,0,0,15"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="GŁÓWNE LICZNIKI (KPI)" Foreground="#888" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <CheckBox Content="Całkowity Utarg" IsChecked="{Binding ShowRevenue}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Średnia Cena Biletu (ATP)" IsChecked="{Binding ShowATP}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Sprzedane Bilety" IsChecked="{Binding ShowSoldTickets}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Zwroty" IsChecked="{Binding ShowReturns}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Średnia Frekwencja" IsChecked="{Binding ShowOccupancy}" Style="{StaticResource SwitchCheckBoxStyle}"/>

                            <TextBlock Text="WYKRESY I TABELE" Foreground="#888" FontWeight="Bold" Margin="0,20,0,10"/>
                            
                            <CheckBox Content="Rozkład Godzinowy" IsChecked="{Binding ShowHourlyChart}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Wykres Dni Tygodnia" IsChecked="{Binding ShowWeeklyChart}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Popularność Gatunków" IsChecked="{Binding ShowGenreChart}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Obłożenie Sal" IsChecked="{Binding ShowHallStats}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Ranking Top 30 Filmów (Przychód)" IsChecked="{Binding ShowTopMovies}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Ranking Top Filmów (Ilość Biletów)" IsChecked="{Binding ShowMoviesTicketCount}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            <CheckBox Content="Wykres Typów Biletów" IsChecked="{Binding ShowTicketTypeChart}" Style="{StaticResource SwitchCheckBoxStyle}"/>
                            
                            </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding ToggleConfigCommand}" Content="ZAPISZ I ZAMKNIJ" 
                            Height="40" Margin="0,20,0,0"
                            Background="#FFD700" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
             </Border>
        </Grid>
        <Grid Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsDayDetailsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="500" Height="400" Background="#252525" CornerRadius="15" BorderBrush="#00ACC1" BorderThickness="1">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDayName}" FontSize="18" FontWeight="Bold" Foreground="#00ACC1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Rozkład godzinowy w wybranym dniu" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <Button Command="{Binding CloseDayDetailsCommand}" Content="✕" 
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" Foreground="Gray" FontSize="16" FontWeight="Bold" 
                                BorderThickness="0" Cursor="Hand" Width="30" Height="30">
                             <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#444" Margin="0,15,0,0"/>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        
                         <TextBlock Text="Brak sprzedaży w tym dniu." Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/> <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedDayHourlySales.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding SelectedDayHourlySales}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                        
                                        <TextBlock Text="{Binding Value}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,2"/>

                                        <Border Width="20" Height="{Binding NormalizedValue}" Background="#00ACC1" CornerRadius="4,4,0,0"/>
                                        
                                        <TextBlock Text="{Binding Label}" Foreground="#888" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    
                    <Button Grid.Row="2" Command="{Binding CloseDayDetailsCommand}" Content="ZAMKNIJ" 
                            Height="35" Width="120" Margin="0,20,0,0"
                            Background="#333" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
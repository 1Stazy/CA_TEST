<Window x:Class="CinemaSystem.Desktop.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CinemaSystem Message" Height="200" Width="400"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#FFD700" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Text="TYTUŁ" 
                       Foreground="#FFD700" FontWeight="Bold" FontSize="16" 
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="MessageText" Text="Treść wiadomości..." 
                       Foreground="White" FontSize="14" TextWrapping="Wrap" 
                       TextAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Margin="0,10"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                
                <Button x:Name="BtnYes" Content="TAK" Click="BtnYes_Click"
                        Width="100" Height="35" Margin="10,0"
                        Background="#E50914" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnNo" Content="NIE" Click="BtnNo_Click"
                        Width="100" Height="35" Margin="10,0"
                        Background="#333" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
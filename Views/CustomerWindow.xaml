<Window x:Class="CinemaSystem.Desktop.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
        xmlns:views="clr-namespace:CinemaSystem.Desktop.Views"
        xmlns:controls="clr-namespace:CinemaSystem.Desktop.Views.Controls"
        mc:Ignorable="d"
        Title="Ekran Klienta" Height="1080" Width="1920"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Black"
        Cursor="None"> <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <ControlTemplate x:Key="ClientSeatTemplate" TargetType="ContentControl">
            <Grid Width="44" Height="48" Margin="2">
                <Grid VerticalAlignment="Top" Height="42">
                    <Grid.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="3" Opacity="0.7"/>
                    </Grid.Effect>

                    <Border x:Name="SeatBack" 
                            Background="#1E1E1E" 
                            BorderBrush="#333" 
                            BorderThickness="2"
                            CornerRadius="4,4,2,2"
                            Margin="6,0,6,10"/>

                    <Border x:Name="SeatCushion"
                            Background="#252525"
                            BorderBrush="#333" BorderThickness="1"
                            CornerRadius="3"
                            Height="16" VerticalAlignment="Bottom" Margin="4,0,4,2"/>

                    <Border Width="5" HorizontalAlignment="Left" Margin="0,12,0,2" 
                            Background="#101010" BorderBrush="#222" BorderThickness="1" CornerRadius="2"/>
                    
                    <Border Width="5" HorizontalAlignment="Right" Margin="0,12,0,2" 
                            Background="#101010" BorderBrush="#222" BorderThickness="1" CornerRadius="2"/>

                    <TextBlock x:Name="SeatNum" Text="{Binding Number}" 
                            Foreground="#666" FontSize="11" FontWeight="Bold" 
                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>
                </Grid>

                <Border x:Name="SeatGlow" VerticalAlignment="Bottom" Height="2" Background="#FFD700" Opacity="0" CornerRadius="1">
                    <Border.Effect><BlurEffect Radius="4"/></Border.Effect>
                </Border>
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Selected">
                    <Setter TargetName="SeatBack" Property="Background" Value="#FFD700"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#E5C100"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#FFD700"/>
                    <Setter TargetName="SeatBack" Property="Effect">
                        <Setter.Value><DropShadowEffect Color="#FFD700" BlurRadius="15" Opacity="0.6"/></Setter.Value>
                    </Setter>
                    <Setter TargetName="SeatNum" Property="Foreground" Value="Black"/>
                    <Setter TargetName="SeatGlow" Property="Opacity" Value="1"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Taken">
                    <Setter TargetName="SeatBack" Property="Background" Value="#350000"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#450000"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#450000"/>
                    <Setter TargetName="SeatNum" Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Editing">
                    <Setter TargetName="SeatBack" Property="Background" Value="#1E88E5"/>
                    <Setter TargetName="SeatBack" Property="BorderBrush" Value="#64B5F6"/>
                    <Setter TargetName="SeatCushion" Property="Background" Value="#1565C0"/>
                    <Setter TargetName="SeatNum" Property="Foreground" Value="White"/>
                    <Setter TargetName="SeatNum" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SeatGlow" Property="Opacity" Value="0.8"/>
                    <Setter TargetName="SeatGlow" Property="Background" Value="#1E88E5"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <DataTemplate DataType="{x:Type vm:SeatSelectionViewModel}">
            <Grid Background="#050505">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="50,30,50,0">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentScreening.TimeString}" Foreground="#FFD700" FontSize="56" FontWeight="Black" Margin="0,0,20,0">
                                <TextBlock.Effect><DropShadowEffect Color="#FFD700" BlurRadius="20" Opacity="0.4"/></TextBlock.Effect>
                            </TextBlock>
                            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12,4" VerticalAlignment="Center" Background="#151515">
                                <TextBlock Text="{Binding CurrentScreening.Hall.Name}" Foreground="#AAA" FontSize="24" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentScreening.Movie.Title}" Foreground="White" FontSize="40" FontWeight="Light" Margin="0,5,0,0" Opacity="0.95"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Path Data="M 0,0 L 800,0 L 740,80 L 60,80 Z" 
                              Fill="#1E1E1E" Stroke="#444" StrokeThickness="3">
                            <Path.Effect><DropShadowEffect Color="#FFD700" BlurRadius="60" Direction="270" Opacity="0.2"/></Path.Effect>
                        </Path>
                        <TextBlock Text="E K R A N" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,-55,0,0" Opacity="0.8"/>
                        <Border Height="6" Width="680" Background="#FFD700" Margin="0,48,0,0" Opacity="0.5" CornerRadius="3">
                            <Border.Effect><BlurEffect Radius="15"/></Border.Effect>
                        </Border>
                    </StackPanel>
                </Grid>

                <Viewbox Grid.Row="1" Stretch="Uniform" Margin="50,10,50,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> 
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0" ItemsSource="{Binding RowLabels}" Margin="0,0,30,0">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50"> <TextBlock Text="{Binding}" Foreground="#FFD700" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.5"/> </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Seats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding ColumnsCount}" Rows="{Binding RowsCount}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Template="{StaticResource ClientSeatTemplate}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2" ItemsSource="{Binding RowLabels}" Margin="30,0,0,0">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50"> <TextBlock Text="{Binding}" Foreground="#FFD700" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Opacity="0.5"/> </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Viewbox>

                <Border Grid.Row="2" Background="#101010" BorderBrush="#222" BorderThickness="0,1,0,0" Padding="30,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Width="24" Height="24" Background="#1E1E1E" CornerRadius="4" BorderBrush="#333" BorderThickness="1" Margin="0,0,10,0"/>
                        <TextBlock Text="Wolne" Foreground="#AAA" FontSize="24" Margin="0,0,50,0" VerticalAlignment="Center"/>
                        
                        <Border Width="24" Height="24" Background="#FFD700" CornerRadius="4" Margin="0,0,10,0">
                            <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="10"/></Border.Effect>
                        </Border>
                        <TextBlock Text="Twój wybór" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,50,0" VerticalAlignment="Center"/>
                        
                        <Border Width="24" Height="24" Background="#1E88E5" CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock Text="Twoje miejsce" Foreground="#64B5F6" FontSize="24" FontWeight="Bold" Margin="0,0,50,0" VerticalAlignment="Center"/>

                        <Border Width="24" Height="24" Background="#350000" CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock Text="Zajęte" Foreground="#555" FontSize="24" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TicketSummaryViewModel}">
            <Grid Background="#121212">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="40" Background="#1E1E1E" CornerRadius="15" Padding="30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="WYBRANE MIEJSCA" Foreground="#FFD700" FontWeight="Bold" FontSize="28" Margin="0,0,0,25"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2A2A2A" CornerRadius="8" Margin="0,0,0,15" Padding="20">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="150"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="50" Height="50" Background="#333" CornerRadius="8" Margin="0,0,20,0">
                                                    <TextBlock Text="{Binding Seat.Number}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Seat.Row, StringFormat='RZĄD {0}'}" Foreground="#888" FontSize="14" FontWeight="Bold"/>
                                                    <TextBlock Text="MIEJSCE" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="#151515" CornerRadius="5" Padding="15,5" VerticalAlignment="Center" Margin="0,0,20,0">
                                                    <TextBlock Text="{Binding SelectedType.Name}" Foreground="#DDD" FontSize="18" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{Binding Price, StringFormat='{}{0:C}'}" Foreground="#FFD700" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Margin="0,40,40,40" Background="#181818" CornerRadius="15" BorderBrush="#333" BorderThickness="1">
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="PODSUMOWANIE" Foreground="Gray" FontSize="16" FontWeight="Bold" Margin="0,0,0,25"/>
                            <TextBlock Text="{Binding MovieTitle}" Foreground="White" FontSize="36" FontWeight="Black" TextWrapping="Wrap" LineHeight="40"/>
                            <TextBlock Text="{Binding ScreeningTime}" Foreground="#FFD700" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding HallName}" Foreground="#AAA" FontSize="20" Margin="0,5,0,0"/>
                            <Separator Background="#333" Margin="0,30"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="DO ZAPŁATY" Foreground="#888" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FinalPrice, StringFormat='{}{0:C}'}" Foreground="#FFD700" FontSize="70" FontWeight="Black" HorizontalAlignment="Center" Margin="0,10"/>
                            <Border Background="#222" CornerRadius="10" Padding="15" Margin="0,30,0,0">
                                <TextBlock Text="Prosimy o uregulowanie płatności u sprzedawcy." Foreground="#AAA" FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MovieDetailViewModel}">
            <Grid Background="#050505">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="6*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="{Binding SelectedFilm.PosterUri}" Stretch="UniformToFill" Opacity="0.8"/>
                <Border Grid.Column="0" Background="#000" Opacity="0.4"/>
                
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden" Margin="60">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedFilm.Genre}" Foreground="#FFD700" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedFilm.Title}" Foreground="White" FontSize="70" FontWeight="Black" TextWrapping="Wrap" LineHeight="70" Margin="0,10,0,30"/>
                        <TextBlock Text="{Binding SelectedFilm.Description}" Foreground="#CCC" FontSize="24" TextWrapping="Wrap" LineHeight="36"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,40,0,0">
                            <TextBlock Text="CZAS TRWANIA: " Foreground="#555" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedFilm.Duration, StringFormat='{}{0} min'}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="  |  OCENA: " Foreground="#555" FontSize="20" FontWeight="Bold" Margin="20,0,0,0"/>
                            <TextBlock Text="{Binding SelectedFilm.ImdbRating}" Foreground="#FFD700" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Background="#333" Margin="0,40"/>

                        <TextBlock Text="NAJBLIŻSZE SEANSE" Foreground="#FFD700" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding FilmScreenings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="160" Margin="0,0,25,25">
                                        <Border Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#252525" CornerRadius="10,10,0,0" Padding="15">
                                                    <TextBlock Text="{Binding TimeString}" Foreground="#FFD700" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Row="1" Padding="15">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DateString}" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{Binding Hall.Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="2" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10">
                                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" Foreground="#AAA" FontSize="12" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock Text="Brak seansów w najbliższym czasie." 
                                   Foreground="Gray" FontStyle="Italic" FontSize="18" 
                                   Visibility="{Binding FilmScreenings.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MoviesViewModel}">
            <Grid>
                <TextBlock Text="REPERTUAR KINA" Foreground="#FFD700" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,50,0,0" Panel.ZIndex="10"/>
                
                <controls:Carousel3DView ItemsSource="{Binding AllActiveMovies}" 
                                         SelectedItem="{Binding ClientSelectedMovie}" 
                                         IsHitTestVisible="False" 
                                         CameraDistance="9" 
                                         Margin="0,40,0,80"/>
                
                <Border VerticalAlignment="Bottom" Background="#111" Height="100" BorderBrush="#333" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="PROMOCJA:" Foreground="#FFD700" FontSize="24" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding CurrentAdText}" Foreground="White" FontSize="24">
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientScheduleViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="40,30,40,20">
                    <TextBlock Text="NAJBLIŻSZE SEANSE" Foreground="#FFD700" FontSize="40" FontWeight="Black"/>
                    <TextBlock Text="Sprawdź co gramy w najbliższym czasie" Foreground="#AAA" FontSize="20" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="40,0,40,40" VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding UpcomingScreenings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> 
                                            <ColumnDefinition Width="*"/>    
                                            <ColumnDefinition Width="Auto"/> 
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#252525" CornerRadius="6" Padding="15,5" Margin="0,0,20,0" MinWidth="100">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Start, StringFormat={}{0:HH:mm}}" Foreground="#FFD700" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Start, StringFormat={}{0:dd.MM}}" Foreground="#AAA" FontSize="14" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Movie.Title}" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Movie.Genre}" Foreground="#888" FontSize="16"/>
                                                <TextBlock Text=" • " Foreground="#444" FontSize="16" Margin="8,0"/>
                                                <TextBlock Text="{Binding Movie.Duration, StringFormat={}{0} min}" Foreground="#888" FontSize="16"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="2" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="15,5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Hall.Name}" Foreground="#AAA" FontSize="16" FontWeight="Medium"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Image Source="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&amp;w=2070&amp;auto=format&amp;fit=crop" Stretch="UniformToFill" Opacity="0.2"/>
        <ContentControl Content="{Binding ClientView, FallbackValue='Ekran Klienta - Oczekiwanie...'}" />
    </Grid>
</Window>
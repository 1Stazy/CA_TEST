<UserControl x:Class="CinemaSystem.Desktop.Views.TicketSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CinemaSystem.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#121212"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="30" Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="KOSZYK BILETÓW" Foreground="#FFD700" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Przeciągnij myszką po biletach, aby zaznaczyć wiele naraz." Foreground="#666" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly"
                              PreviewMouseDown="OnListMouseDown"
                              PreviewMouseMove="OnListMouseMove"
                              PreviewMouseUp="OnListMouseUp">
                    
                    <ItemsControl x:Name="TicketsList" ItemsSource="{Binding CartItems}" Background="Transparent" Margin="0,0,10,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,12" Padding="20,15" BorderThickness="1" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E1E1E"/>
                                            <Setter Property="BorderBrush" Value="#333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#252525"/>
                                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FFD700" BlurRadius="15" Opacity="0.4" ShadowDepth="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="50" Height="50" Background="#121212" CornerRadius="8" Margin="0,0,20,0" BorderBrush="#333" BorderThickness="1">
                                            <Grid>
                                                <TextBlock Text="{Binding Seat.Number}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Seat.Row}" Foreground="#666" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,3"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedType.Name}" Foreground="#FFD700" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Rząd " Foreground="#888" FontSize="13"/>
                                                <TextBlock Text="{Binding Seat.Row}" Foreground="#AAA" FontSize="13" FontWeight="Bold"/>
                                                <TextBlock Text=", Miejsce " Foreground="#888" FontSize="13" Margin="5,0,0,0"/>
                                                <TextBlock Text="{Binding Seat.Number}" Foreground="#AAA" FontSize="13" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='{}{0:C}'}" 
                                                   Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0,30,30,30">
            
            <Border CornerRadius="15" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding PosterUri}" Stretch="UniformToFill" Opacity="0.3">
                        <Image.Effect>
                            <BlurEffect Radius="40"/>
                        </Image.Effect>
                    </Image>
                    <Border Background="#D9121212"/>
                </Grid>
            </Border>

            <Border CornerRadius="15" BorderBrush="#333" BorderThickness="1" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <TextBlock Text="PODSUMOWANIE" Foreground="#666" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding MovieTitle}" Foreground="White" FontSize="26" FontWeight="Black" TextWrapping="Wrap" LineHeight="30"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="{Binding ScreeningTime}" Foreground="#FFD700" FontSize="14" FontWeight="SemiBold" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding HallName}" Foreground="#AAA" FontSize="14"/>
                        </StackPanel>
                        <Separator Background="#333" Margin="0,20"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Visibility="{Binding IsNotFinished, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="SZYBKA ZMIANA DLA ZAZNACZONYCH:" Foreground="#FFD700" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding AvailableTicketTypes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" 
                                            Command="{Binding DataContext.ApplyDiscountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,8" Padding="15,6"
                                            Background="Transparent" Foreground="White" BorderBrush="#555" BorderThickness="1"
                                            Cursor="Hand" FontSize="11" FontWeight="SemiBold">
                                        <Button.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style>
                                        </Button.Resources>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="15">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#333"/>
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#FFD700"/>
                                                        <Setter Property="Foreground" Value="#FFD700"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#FFD700"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Separator Background="#333" Margin="0,15,0,25"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Visibility="{Binding IsNotFinished, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="DANE KLIENTA" Foreground="#FFD700" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Imię i Nazwisko" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border CornerRadius="5" Background="#121212" BorderBrush="#444" BorderThickness="1">
                                <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Adres E-mail (opcjonalnie)" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border CornerRadius="5" Background="#121212" BorderBrush="#444" BorderThickness="1">
                                <TextBox Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Kod Rabatowy" Foreground="#888" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="5" Background="#121212" BorderBrush="#444" BorderThickness="1">
                                    <TextBox Text="{Binding PromoCodeInput, UpdateSourceTrigger=PropertyChanged}" 
                                             Padding="10" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"
                                             CharacterCasing="Upper"/>
                                </Border>
                                <Button Grid.Column="1" Content="UŻYJ" Command="{Binding ApplyPromoCodeCommand}"
                                        Background="#FFD700" Foreground="Black" FontWeight="Bold"
                                        Padding="20,0" Margin="10,0,0,0" BorderThickness="0" Cursor="Hand" Height="38">
                                    <Button.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                        
                        <StackPanel Margin="0,20,0,25">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Wartość biletów:" Foreground="#888" FontSize="14"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TotalPrice, StringFormat='{}{0:N2} zł'}" Foreground="#AAA" FontSize="14"/>
                            </DockPanel>
                            
                            <DockPanel LastChildFill="False" Margin="0,5,0,0" Visibility="{Binding DiscountVisibility}">
                                <TextBlock Text="Rabat:" Foreground="#EF5350" FontSize="14"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding DiscountAmount, StringFormat='-{0:N2} zł'}" Foreground="#EF5350" FontSize="14"/>
                            </DockPanel>

                            <Separator Background="#444" Margin="0,10"/>

                            <DockPanel LastChildFill="False">
                                <TextBlock Text="DO ZAPŁATY:" Foreground="#AAA" FontSize="16" FontWeight="Bold" VerticalAlignment="Bottom"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding FinalPrice, StringFormat='{}{0:N2}'}" Foreground="#FFD700" FontSize="36" FontWeight="Black">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#FFD700" BlurRadius="15" Opacity="0.3"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text=" PLN" Foreground="#FFD700" FontSize="18" FontWeight="Bold" Margin="5,0,0,6" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsNotFinished, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Command="{Binding FinalizeTransactionCommand}"
                                    Height="55" Margin="0,0,0,15" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBdr" Background="#E50914" CornerRadius="8">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#E50914" BlurRadius="15" Opacity="0.4" ShadowDepth="3"/>
                                            </Border.Effect>
                                            <TextBlock Text="ZATWIERDŹ I DRUKUJ" Foreground="White" FontWeight="Bold" FontSize="16" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBdr" Property="Background" Value="#FF1F2F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="WRÓĆ" Command="{Binding GoBackCommand}" 
                                    Background="Transparent" Foreground="#666" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                            
                            <ProgressBar Value="{Binding ProgressValue}" Height="4" Margin="0,15,0,0" 
                                         Background="#333" Foreground="#FFD700" BorderThickness="0"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsTransactionFinished, Converter={StaticResource BooleanToVisibilityConverter}}">
                             <Border Background="#1A3B2A" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                <TextBlock Text="✓ TRANSAKCJA ZAKOŃCZONA" Foreground="#2ECC71" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Button Content="ZAKOŃCZ" Command="{Binding FinishAndExitCommand}" Background="#333" Foreground="White" Height="45" FontWeight="Bold">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>